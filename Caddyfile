YOUR_DOMAIN {
    # Reverse proxy all traffic to FastAPI (serves both API and static frontend)
    reverse_proxy sentinel:8000

    # CORS headers for Vercel frontend -> EC2 backend
    header {
        Access-Control-Allow-Origin *
        Access-Control-Allow-Methods "GET, POST, OPTIONS"
        Access-Control-Allow-Headers "Content-Type, Authorization"
    }
}
