{
  "buildCommand": "cd frontend && npm run build",
  "outputDirectory": "frontend/dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_EC2_DOMAIN/api/:path*"
    },
    {
      "source": "/health",
      "destination": "https://YOUR_EC2_DOMAIN/health"
    }
  ]
}
