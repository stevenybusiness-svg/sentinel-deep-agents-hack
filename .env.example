# Sentinel -- Environment Variables
# Copy to .env and fill in values

# === Required for core functionality ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Aerospike (Aerospike Cloud: host/port from cluster dashboard, user/password required) ===
AEROSPIKE_HOST=localhost
AEROSPIKE_PORT=3000
AEROSPIKE_NAMESPACE=sentinel
AEROSPIKE_USER=
AEROSPIKE_PASSWORD=

# === Bland AI Voice (optional -- voice disabled if empty) ===
BLAND_API_KEY=
DEMO_PHONE_NUMBER=

# === Auth0 (SPA application -- auth0.com dashboard) ===
# Auth0 Dashboard -> Applications -> Create Application -> Single Page Web Applications
# Set Allowed Callback/Logout URLs and Allowed Web Origins to your deployment URL
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-client-id

# === Slack Incoming Webhook ===
# Get webhook URL from: Slack App Dashboard -> Features -> Incoming Webhooks -> Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# === Deployment ===
PUBLIC_HOST=http://localhost:8000

# === Vercel Frontend (set in Vercel dashboard for production) ===
# These are used at BUILD TIME by Vite (prefix VITE_ required)
VITE_API_URL=
VITE_WS_URL=

# === LLM Backend (default: anthropic) ===
# LLM_BACKEND=anthropic
# LLM_BACKEND=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SUPERVISOR_MODEL=
# AGENT_MODEL=
