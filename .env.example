# Sentinel -- Environment Variables
# Copy to .env and fill in values

# === Required for core functionality ===
ANTHROPIC_API_KEY=sk-ant-your-key-here

# === Aerospike (override for Docker/Railway) ===
AEROSPIKE_HOST=localhost
AEROSPIKE_PORT=3000
AEROSPIKE_NAMESPACE=sentinel

# === Bland AI Voice (optional -- voice disabled if empty) ===
BLAND_API_KEY=
DEMO_PHONE_NUMBER=

# === Airbyte + Slack report delivery (DEMO-POLISH-04) ===
# Get webhook URL from: Slack App Dashboard -> Features -> Incoming Webhooks -> Add New Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# === Deployment (set on Railway/cloud only) ===
PUBLIC_HOST=http://localhost:8000

# === LLM Backend (default: anthropic) ===
# LLM_BACKEND=anthropic
# LLM_BACKEND=bedrock
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# SUPERVISOR_MODEL=
# AGENT_MODEL=
